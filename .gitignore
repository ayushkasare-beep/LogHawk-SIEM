# ====================================
# LogHawk – Git Ignore Configuration
# ====================================

# ---- Node.js / npm ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Environment Variables ----
# NEVER commit .env files – they contain secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env

# ---- Build Outputs ----
frontend/dist/
frontend/build/
backend/dist/

# ---- Python ----
__pycache__/
python-engine/__pycache__/
python-engine/**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
backend/logs/*.log

# ---- Uploads (user data – excluded from repo, preserved by .gitkeep) ----
backend/uploads/*
!backend/uploads/.gitkeep

# ---- Python Engine Output ----
python-engine/reports/*
!python-engine/reports/.gitkeep

# ---- OS / System Files ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Test Coverage ----
coverage/
.nyc_output/

# ---- Archives ----
*.tgz
*.tar.gz
*.zip
