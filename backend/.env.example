# ====================================
# LogHawk Backend – Environment Variables
# ====================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/loghawk

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Python Engine Path
PYTHON_ENGINE_PATH=../python-engine

# Python interpreter command (defaults to 'python' from system PATH if not set)
# Set this if your Python binary is not in PATH or has a different name:
# PYTHON_PATH=python3
# PYTHON_PATH=C:\Users\YourName\AppData\Local\Programs\Python\Python311\python.exe
